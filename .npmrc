# Don't run pnpm's pre-script dependency re-check before `pnpm seed` /
# `pnpm dev`. That check spawns a synchronous `pnpm install` whose only
# failure mode here was the ignored-build-scripts warning being treated as
# a hard error (exit 1), which blocked the scripts from running at all on
# a fresh clone. Builds are handled deterministically via
# pnpm-workspace.yaml's onlyBuiltDependencies, so the pre-check adds no
# value and only risks blocking a reviewer. Safety net for plug-and-play.
verify-deps-before-run=false
