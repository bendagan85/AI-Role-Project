# Copy this file to .env.local and fill in the two LLM keys.
#
#   cp .env.example .env.local
#
# The Supabase values below are the Supabase CLI's well-known LOCAL dev
# defaults — they work out of the box with `npx supabase start` (full
# Postgres + Auth + Storage in Docker, migrations auto-applied). They are
# NOT secrets (published in Supabase's docs, identical on every machine).
# For HOSTED Supabase instead, replace the three values with your project's
# (Settings → API) — see README "Local Development → Option B".

# ---------- Supabase (local-CLI defaults; override for hosted) ----------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Service role key — server-only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ---------- LLM providers (REQUIRED — you must supply these) ----------
# OpenAI — embeddings (text-embedding-3-small) + fallback chat model.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — default chat model (Claude Sonnet) + the category classifier.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- Inngest (OPTIONAL for local) ----------
# Only needed to ingest NEW documents locally (run `npx inngest-cli@latest
# dev` in a second terminal). The two demo coaches are pre-seeded by
# `pnpm seed` WITHOUT Inngest, so chat/admin work without these. Required
# in production (Vercel) — set them in the Vercel dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- App ----------
# Public base URL. Leave as localhost for local dev; set to the Vercel URL
# in production (used for absolute links e.g. the widget embed URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000
