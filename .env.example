# ---------- Supabase ----------
# Project URL and anon key — Settings → API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Settings → API. Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- LLM providers ----------
# OpenAI — used for embeddings (text-embedding-3-small) and as a fallback chat model.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — default chat model (Claude Sonnet).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- Inngest (ingestion background jobs) ----------
# https://app.inngest.com — create an app, copy the keys from the env page.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- App ----------
# Public base URL of the deployed app. Used in absolute links (e.g., widget embed).
# Leave blank for local dev; set to the Vercel URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
